{
  "manifest_version": 3,
  "name": "Job Capture",
  "version": "2.0.0",
  "description": "Extract job info from job postings and save to Google Sheets.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Capture"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
